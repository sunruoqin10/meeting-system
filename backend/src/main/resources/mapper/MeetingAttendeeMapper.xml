<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.meet.mapper.MeetingAttendeeMapper">

    <insert id="insert">
        INSERT INTO meeting_attendees (id, minute_id, user_id, role, attended, created_time)
        VALUES (#{id}, #{minuteId}, #{userId}, #{role}, #{attended}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM meeting_attendees WHERE id = #{id}
    </delete>

    <delete id="deleteByMinuteId">
        DELETE FROM meeting_attendees WHERE minute_id = #{minuteId}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM meeting_attendees WHERE user_id = #{userId}
    </delete>

</mapper>
